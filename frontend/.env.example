# 이 파일을 복사해서 .env.local 로 만들고 값을 채워주세요: cp .env.example .env.local

# 실제 백엔드 API를 사용할 때 아래 값을 설정하세요.
# 값이 없으면 자동으로 mock 데이터를 사용합니다.
# 로컬 백엔드
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
#
# 운영 백엔드 (Railway 예시)
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
#
# 주의: URL 끝에 슬래시(/)를 붙이지 마세요.
#
# 로컬에서 백엔드(origin http://localhost:3000)를 부를 때는
# Railway·백엔드 설정의 CORS_ORIGINS에 같은 주소가 포함되어 있어야 합니다.

# 공공데이터포털(odcloud) 키 (선택)
# /support/consulting 페이지에서 지역·업종별 장려금 지원 사업체 현황 API 조회에 사용
# 둘 중 하나만 있어도 동작하며, 없으면 앱 내 fallback 데이터로 표시됩니다.
# ODCLOUD_SERVICE_KEY=your_service_key
# ODCLOUD_AUTHORIZATION=Infuser your_authorization_token

# 한국장애인고용공단 표준사업장 실시간 조회(apis.data.go.kr)에도 동일 인증키 사용
# 예: https://apis.data.go.kr/B552583/comp/comp_auth
