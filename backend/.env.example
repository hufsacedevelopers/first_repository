APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# 공공데이터포털(ODCloud) 키 — 장려금 연도별 통계(API) 등
ODCLOUD_API_KEY=your_decoding_service_key
ODCLOUD_BASE_URL=https://api.odcloud.kr/api

# data.go.kr XML API (구인·표준사업장). 우선순위: DATA_GO_API_KEY > B552583_API_KEY > (서비스 코드에서) ODCLOUD_API_KEY
DATA_GO_API_KEY=
# DATA_GO_API_KEY가 비어 있을 때만 data.go.kr 호출에 사용 (구 명칭 호환)
B552583_API_KEY=
DATA_GO_BASE_URL=https://apis.data.go.kr/B552583/comp
DATA_GO_JOB_BASE_URL=https://apis.data.go.kr/B552583/job

# 경기도 Open API (장애인활동지원기관현황 — openapi.gg.go.kr 에서 발급, 없으면 접근성 점수 스킵)
GG_API_KEY=
GG_API_BASE_URL=https://openapi.gg.go.kr/DisaActvSuprtInstList

# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
