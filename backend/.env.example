APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# 공공데이터포털(ODCloud) 키
ODCLOUD_API_KEY=your_decoding_service_key
ODCLOUD_BASE_URL=https://api.odcloud.kr/api

# data.go.kr XML API (비워두면 ODCLOUD_API_KEY 재사용)
DATA_GO_API_KEY=
DATA_GO_BASE_URL=https://apis.data.go.kr/B552583/comp
DATA_GO_JOB_BASE_URL=https://apis.data.go.kr/B552583/job
# 경기도 Open API (장애인활동지원기관현황 — openapi.gg.go.kr 에서 발급)
GG_API_KEY=
GG_API_BASE_URL=https://openapi.gg.go.kr/DisaActvSuprtInstList

# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
# data.go.kr API 키
B552583_API_KEY=your_api_key

# data.go.kr API 기본 URL
DATA_GO_BASE_URL=https://apis.data.go.kr/B552583/comp
DATA_GO_JOB_BASE_URL=https://apis.data.go.kr/B552583/job